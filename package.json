{
  "name": "ganhammar",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "API_TOKEN=${API_TOKEN:-$(gh auth token)} vite dev",
    "build": "svelte-kit sync && vite build && npm run build:lambda && npm run build:package",
    "build:lambda": "esbuild lambda/handler.ts --bundle --platform=node --target=node20 --format=esm --outfile=build/handler.js --external:./server/* --external:./client/*",
    "build:package": "echo '{\"type\":\"module\"}' > build/package.json",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "cdk": "cdk",
    "deploy": "cdk deploy --require-approval never --app 'npx tsx infra/bin/app.ts'"
  },
  "dependencies": {
    "hast-util-to-html": "^9.0.5",
    "lowlight": "^3.3.0",
    "marked": "^18.0.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.63.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^25.9.2",
    "aws-cdk": "^2.1126.0",
    "aws-cdk-lib": "^2.258.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.28.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
